---
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Thank you for contacting Tootie Designs." />
    <title>Inquiry Received | Tootie Designs</title>
  </head>
  <body>
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href={basePath} aria-label="Tootie Designs home">
        <span class="brand-mark"><img src={`${basePath}tootie-logo-transparent.png`} alt="" /></span>
        <span>Tootie Designs</span>
      </a>
      <nav>
        <a href={`${basePath}#work`}>Work</a>
        <a href={`${basePath}#capabilities`}>Capabilities</a>
        <a href={`${basePath}#process`}>Process</a>
        <a href={`${basePath}notes/`}>Notes</a>
        <a href={`${basePath}#contact`}>Contact</a>
      </nav>
    </header>

    <main>
      <section class="thanks-page section-shell" aria-labelledby="thanks-title">
        <p class="eyebrow">Inquiry Received</p>
        <h1 id="thanks-title">Thanks for reaching out.</h1>
        <p class="hero-copy">
          Your project brief has been sent to Tootie Designs. We will review the details
          and follow up with a clear next step.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={basePath}>Return Home</a>
          <a class="button secondary" href={`${basePath}#work`}>View the Work</a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div>
        <strong>Tootie Designs</strong>
        <span>Fayetteville, NC</span>
      </div>
      <div>
        <span>Website Design / Software / Tactical Advising / Fabrication</span>
        <span>Precision / Texture / Innovation</span>
        <span>© {currentYear} Tootie Designs.</span>
        <div class="footer-links">
          <a href="https://www.facebook.com/profile.php?id=100063801085109" target="_blank" rel="noreferrer">Facebook</a>
          <a href={`${basePath}privacy/`}>Privacy Policy</a>
        </div>
      </div>
    </footer>
  </body>
</html>
