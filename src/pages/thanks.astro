---
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <meta name="description" content="Your Tootie Designs website audit request has been received." />
    <title>Audit Request Received | Tootie Designs</title>
  </head>
  <body>
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href={basePath} aria-label="Tootie Designs home">
        <span class="brand-mark"><img src={`${basePath}tootie-logo-transparent.png`} alt="" width="37" height="37" /></span>
        <span>Tootie Designs</span>
      </a>
      <nav>
        <a href={`${basePath}website-design/`}>Websites</a>
        <a href={`${basePath}website-redesign/`}>Redesigns</a>
        <a href={`${basePath}landing-page-design/`}>Landing Pages</a>
        <a href={`${basePath}local-business-websites/`}>Local</a>
        <a href={`${basePath}#work`}>Work</a>
        <a href={`${basePath}#audit`}>Free Audit</a>
      </nav>
    </header>

    <main>
      <section class="thanks-page section-shell" aria-labelledby="thanks-title">
        <div class="thanks-copy">
          <p class="eyebrow">Audit Request Received</p>
          <h1 id="thanks-title">Your website audit request is in.</h1>
          <p class="hero-copy">
            Tootie Designs will review your first impression, mobile experience, message clarity, trust signals, and lead path — then follow up with the clearest next move.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={`${basePath}sample-website-audit/`} data-event="sample_audit_click" data-label="thanks sample audit">Review the Sample Audit</a>
            <a class="button secondary" href={`${basePath}website-redesign/`} data-event="service_page_click" data-label="thanks redesign">See What a Redesign Fixes</a>
          </div>
        </div>

        <aside class="thanks-next-card" aria-label="What happens next">
          <span>What happens next</span>
          <ol>
            <li><strong>First impression review</strong><p>We check whether the site explains the business clearly in the first few seconds.</p></li>
            <li><strong>Mobile trust pass</strong><p>We look for friction on phone screens, CTA access, spacing, and readability.</p></li>
            <li><strong>Proof + lead path check</strong><p>We identify missing trust signals and the fastest path to more confident inquiries.</p></li>
          </ol>
        </aside>
      </section>
    </main>

    <footer class="site-footer">
      <div>
        <strong>Tootie Designs</strong>
        <span>Fayetteville, NC</span>
      </div>
      <div>
        <span>Website Design / Landing Pages / Digital Systems</span>
        <span>Premium first impressions built to generate better leads.</span>
        <span>© {currentYear} Tootie Designs.</span>
        <div class="footer-links">
          <a href="https://www.facebook.com/profile.php?id=100063801085109" target="_blank" rel="noreferrer">Facebook</a>
          <a href={`${basePath}privacy/`}>Privacy Policy</a>
        </div>
      </div>
    </footer>
    <script src={`${basePath}analytics-events.js`} defer></script>
  </body>
</html>
