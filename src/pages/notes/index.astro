---
import "../../styles/global.css";
import { fieldNotes } from "../../data/site";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const currentYear = new Date().getFullYear();

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Field notes from Tootie Designs — thinking on web design, software architecture, defense systems, and material craft."
    />
    <title>Field Notes | Tootie Designs</title>
  </head>
  <body>
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href={basePath} aria-label="Tootie Designs home">
        <span class="brand-mark"><img src={`${basePath}tootie-logo-transparent.png`} alt="" width="37" height="37" /></span>
        <span>Tootie Designs and Strategic Advisor</span>
      </a>
      <nav>
        <a href={`${basePath}#work`}>Work</a>
        <a href={`${basePath}#capabilities`}>Capabilities</a>
        <a href={`${basePath}#process`}>Process</a>
        <a href={`${basePath}notes/`} aria-current="page">Notes</a>
        <a href={`${basePath}#contact`}>Contact</a>
      </nav>
    </header>

    <main>
      <section class="notes-index-hero section-shell" aria-labelledby="notes-hero-title">
        <a class="back-link" href={basePath}>Back to Home</a>
        <p class="eyebrow">Field Notes</p>
        <h1 id="notes-hero-title">Thinking from the studio.</h1>
        <p class="hero-copy">
          Notes on web design, software architecture, defense-informed systems,
          and material craft from Tootie Designs in Fayetteville, NC.
        </p>
      </section>

      <section class="section-shell notes-index-grid-section" aria-labelledby="all-notes-title">
        <h2 id="all-notes-title" class="sr-only">All Field Notes</h2>
        <div class="notes-list-grid">
          {
            fieldNotes.map((note) => (
              <a class="note-card" href={`${basePath}notes/${note.slug}/`}>
                <span class="note-eyebrow">{note.eyebrow}</span>
                <strong>{note.title}</strong>
                <p>{note.summary}</p>
                <span class="note-date">{formatDate(note.date)}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section-shell contact case-contact" id="contact" aria-labelledby="notes-contact-title">
        <div>
          <p class="eyebrow">Start a Project</p>
          <h2 id="notes-contact-title">Ready to put this thinking to work?</h2>
          <p>
            Bring the goal, audience, and constraints. Tootie Designs can shape the
            system, site, or engagement from there.
          </p>
        </div>
        <a class="button primary" href={`${basePath}#contact`}>Open the Project Brief</a>
      </section>
    </main>

    <footer class="site-footer">
      <div>
        <strong>Tootie Designs</strong>
        <span>Fayetteville, NC</span>
      </div>
      <div>
        <span>Website Design / Software / Tactical Advising / Fabrication</span>
        <span>Precision / Texture / Innovation</span>
        <span>© {currentYear} Tootie Designs.</span>
        <div class="footer-links">
          <a href="https://www.facebook.com/profile.php?id=100063801085109" target="_blank" rel="noreferrer">Facebook</a>
          <a href={`${basePath}privacy/`}>Privacy Policy</a>
        </div>
      </div>
    </footer>
  </body>
</html>
