---
import "../styles/global.css";
import LaserIntro from "../components/LaserIntro";
import { capabilities, process as processSteps, projectNotes, projects, tech, websiteShowcase } from "../data/site";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const deploymentOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "https://tootiedesigns.com";
const deploymentBase = `${deploymentOrigin}${base === "/" ? "" : base.replace(/\/$/, "")}`;
const filters = [
  { value: "all", label: "All" },
  { value: "digital", label: "Digital Systems" },
  { value: "tactical", label: "Tactical Consulting" },
  { value: "fabrication", label: "Physical Fabrication" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Tootie Designs is a Fayetteville, NC multidisciplinary creative studio building precision software, tactical systems, laser fabrication, woodworking, and material craft."
    />
    <title>Tootie Designs | Multidisciplinary Creation</title>
  </head>
  <body>
    <LaserIntro client:load />
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href="#top" aria-label="Tootie Designs home">
        <span class="brand-mark"><img src={`${basePath}tootie-logo-transparent.png`} alt="" /></span>
        <span>Tootie Designs</span>
      </a>
      <nav>
        <a href="#work">Work</a>
        <a href="#capabilities">Capabilities</a>
        <a href="#process">Process</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero section-shell" aria-labelledby="hero-title">
        <div class="hero-media" aria-hidden="true">
          <img src={`${basePath}hero-workshop.png`} alt="" />
          <div class="scanline"></div>
        </div>
        <div class="hero-content">
          <p class="eyebrow">Fayetteville, NC / Digital Workshop</p>
          <h1 id="hero-title">Precision-built systems. Hand-finished creations.</h1>
          <p class="hero-copy">
            Tootie Designs bridges defense-grade problem solving, full-stack software,
            laser fabrication, woodworking, and material craft into one multidisciplinary studio.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#work">View the Work</a>
            <a class="button secondary" href="#contact">Start a Project</a>
          </div>
        </div>
        <aside class="hero-panel" aria-label="Studio pillars">
          <div>
            <span>01</span>
            <strong>Precision</strong>
            <p>Software, defense planning, and operational structure.</p>
          </div>
          <div>
            <span>02</span>
            <strong>Texture</strong>
            <p>Wood grain, material pattern, engraved depth, and finish.</p>
          </div>
          <div>
            <span>03</span>
            <strong>Innovation</strong>
            <p>Laser designs, interfaces, prototypes, and deployable tools.</p>
          </div>
        </aside>
      </section>

      <section class="trust-line section-shell" aria-label="Studio trust statement">
        <p>
          Websites, software systems, and crafted goods built with defense-grade precision
          and studio-level finish.
        </p>
      </section>

      <section class="statement section-shell" aria-label="Brand statement">
        <p class="bridge-highlight active">
          <span>Applying the </span><span class="highlight-bit">precision</span><span> of military planning and the logic of </span><span class="highlight-bit">full-stack engineering</span><span> to every medium, from digital interfaces to </span><span class="highlight-bit">physical fabrication</span><span>.</span>
        </p>
      </section>

      <section class="proof-band section-shell" aria-label="Studio proof points">
        <div>
          <span>01</span>
          <strong>Strategy to launch</strong>
          <p>Positioning, copy, interface design, development, and deployment.</p>
        </div>
        <div>
          <span>02</span>
          <strong>Defense-informed precision</strong>
          <p>Built from Fayetteville, NC with respect for clarity, service, and execution.</p>
        </div>
        <div>
          <span>03</span>
          <strong>Digital and physical craft</strong>
          <p>Software, websites, fabrication, wood, and material work under one disciplined studio.</p>
        </div>
      </section>

      <section class="brand-lockup section-shell" aria-label="Brand system">
        <div class="brand-sigil"><img src={`${basePath}tootie-logo-transparent.png`} alt="Tootie Designs multidisciplinary creation logo" /></div>
        <div>
          <p class="eyebrow">Studio Standard</p>
          <h2>Design that can brief, build, and finish.</h2>
        </div>
        <p>
          Tootie Designs combines strategic web creation, defense-informed systems thinking,
          and tactile fabrication under a single visual language: industrial elegance,
          disciplined grids, dark materials, and precise finish.
        </p>
      </section>

      <section class="section-shell" id="capabilities" aria-labelledby="capabilities-title">
        <div class="section-heading">
          <p class="eyebrow">Capabilities</p>
          <h2 id="capabilities-title">Built like a system. Finished like an object.</h2>
        </div>
        <div class="capability-grid">
          {
            capabilities.map((capability) => (
              <article class="capability-card">
                <p>{capability.kicker}</p>
                <h3>{capability.title}</h3>
                <span></span>
                <p>{capability.description}</p>
                <ul>
                  {capability.services.map((service) => <li>{service}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-shell website-showcase" aria-labelledby="website-showcase-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Website Design Showcase</p>
            <h2 id="website-showcase-title">Digital Lab builds made to look credible on arrival.</h2>
          </div>
          <a class="button secondary" href={`${basePath}work/website-design-portfolio/`}>View Website Case Study</a>
        </div>
        <div class="website-grid">
          {
            websiteShowcase.map((item) => (
              <article class="website-card">
                <div class="website-frame" aria-hidden="true">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
                <p class="eyebrow">{item.type}</p>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
                <div>
                  {item.highlights.map((highlight) => <span>{highlight}</span>)}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-shell work-section" id="work" aria-labelledby="work-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Selected Work</p>
            <h2 id="work-title">A portfolio organized by discipline, not by limitation.</h2>
          </div>
        </div>

        <div class="filter-bar" aria-label="Project filters">
          {
            filters.map((filter, index) => (
              <button class={index === 0 ? "filter-button active" : "filter-button"} type="button" data-filter={filter.value}>
                {filter.label}
              </button>
            ))
          }
        </div>

        <div class="project-grid" data-project-grid>
          {
            projects.map((project) => (
              <a
                href={`${basePath}work/${project.slug}/`}
                class={`project-card spotlight-card ${project.size}`}
                data-category={project.filter}
                style="--spotlight-x:50%;--spotlight-y:50%;--tilt-x:0deg;--tilt-y:0deg"
              >
                <div class="project-texture" aria-hidden="true"></div>
                <div class="project-topline">
                  <span>{project.category}</span>
                  <span>{project.meta}</span>
                </div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <span class="project-link">View Case Study</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section-shell blueprint" aria-labelledby="blueprint-title">
        <div class="blueprint-visual perspective-visual" aria-hidden="true">
          <div class="perspective-grid">
            {Array.from({ length: 18 }).map((_, index) => <span class="grid-line horizontal" style={`--i:${index}`}></span>)}
            {Array.from({ length: 15 }).map((_, index) => <span class="grid-line vertical" style={`--i:${index}`}></span>)}
          </div>
          <div class="vector-card">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="material-card"></div>
        </div>
        <div class="blueprint-copy">
          <p class="eyebrow">Blueprint to Reality</p>
          <h2 id="blueprint-title">From concept path to finished surface.</h2>
          <p>
            Every engagement moves through the same disciplined arc: clarify the target,
            design the system, execute the build, then refine the finish until the work
            feels inevitable.
          </p>
        </div>
      </section>

      <section class="section-shell" id="process" aria-labelledby="process-title">
        <div class="section-heading">
          <p class="eyebrow">Process</p>
          <h2 id="process-title">The workshop method.</h2>
        </div>
        <div class="process-grid">
          {
            processSteps.map(([number, title, description]) => (
              <article class="process-card">
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="tech-ticker" aria-label="Technology and materials">
        <div>
          {[...tech, ...tech].map((item) => <span>{item}</span>)}
        </div>
      </section>

      <section class="section-shell project-notes" aria-labelledby="notes-title">
        <div class="section-heading">
          <p class="eyebrow">Testimonials / Project Notes</p>
          <h2 id="notes-title">Named proof, ready for real voices.</h2>
        </div>
        <div class="notes-grid">
          {
            projectNotes.map((note) => (
              <figure>
                <blockquote>{note.quote}</blockquote>
                <figcaption>
                  <strong>{note.name}</strong>
                  <span>{note.projectType}</span>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </section>

      <section class="section-shell about" aria-labelledby="about-title">
        <p class="eyebrow">About the Studio</p>
        <h2 id="about-title">Multidisciplinary creation, grounded in Fayetteville precision.</h2>
        <p>
          Tootie Designs was built on the belief that precision is not limited to one
          medium. The same logic that shapes software architecture can guide a laser path.
          The same discipline behind tactical planning can appear in a clean interface, a
          finished wood surface, or the repeated structure of a material pattern.
        </p>
      </section>

      <section class="section-shell contact" id="contact" aria-labelledby="contact-title">
        <div>
          <p class="eyebrow">Start a Project</p>
          <h2 id="contact-title">Bring the mission, material, or idea.</h2>
          <p>
            Whether the need is a planning tool, a polished web system, a fabricated
            component, or a crafted commission, the first step is a clear brief.
          </p>
        </div>
        <form name="contact" method="post" action="https://formsubmit.co/tootiedesigns18@gmail.com">
          <input type="hidden" name="_subject" value="New Tootie Designs Inquiry" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value={`${deploymentBase}/thanks/`} />
          <input type="text" name="_honey" class="form-honey" tabindex="-1" autocomplete="off" />
          <label>
            Name
            <input name="name" autocomplete="name" required />
          </label>
          <label>
            Email
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label>
            Project Type
            <select name="project-type">
              <option>Website Design / Creation</option>
              <option>Software / Web App Project</option>
              <option>Defense / Consulting Inquiry</option>
              <option>Laser / Wood Fabrication</option>
              <option>Handmade / Material Commission</option>
              <option>General Collaboration</option>
            </select>
          </label>
          <label>
            Timeline
            <select name="timeline">
              <option>Exploring options</option>
              <option>Ready to start this month</option>
              <option>Need a fast launch</option>
              <option>Planning for a future phase</option>
            </select>
          </label>
          <label>
            Budget Range
            <select name="budget">
              <option>Not sure yet</option>
              <option>Under $1,000</option>
              <option>$1,000 - $3,000</option>
              <option>$3,000 - $7,500</option>
              <option>$7,500+</option>
            </select>
          </label>
          <label>
            Existing Website or Reference
            <input name="reference" type="url" placeholder="https://" />
          </label>
          <label>
            Brief
            <textarea name="brief" rows="4" required></textarea>
          </label>
          <button class="button primary" type="submit">Send Inquiry</button>
        </form>
      </section>
    </main>

    <footer class="site-footer">
      <div>
        <strong>Tootie Designs</strong>
        <span>Fayetteville, NC</span>
      </div>
      <div>
        <span>Website Design / Software / Tactical Consulting / Fabrication</span>
        <span>Precision / Texture / Innovation</span>
        <a href="https://www.facebook.com/profile.php?id=100063801085109" target="_blank" rel="noreferrer">Facebook</a>
      </div>
    </footer>
    <script is:inline>
      const filterButtons = document.querySelectorAll("[data-filter]");
      const projectCards = document.querySelectorAll(".project-card[data-category]");

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const activeFilter = button.dataset.filter;
          filterButtons.forEach((item) => item.classList.toggle("active", item === button));
          projectCards.forEach((card) => {
            card.classList.toggle("is-hidden", activeFilter !== "all" && card.dataset.category !== activeFilter);
          });
        });
      });

      projectCards.forEach((card) => {
        card.addEventListener("pointermove", (event) => {
          const rect = card.getBoundingClientRect();
          const px = (event.clientX - rect.left) / rect.width;
          const py = (event.clientY - rect.top) / rect.height;
          card.style.setProperty("--spotlight-x", `${px * 100}%`);
          card.style.setProperty("--spotlight-y", `${py * 100}%`);
          card.style.setProperty("--tilt-x", `${(0.5 - py) * 5}deg`);
          card.style.setProperty("--tilt-y", `${(px - 0.5) * 6}deg`);
        });

        card.addEventListener("pointerleave", () => {
          card.style.setProperty("--spotlight-x", "50%");
          card.style.setProperty("--spotlight-y", "50%");
          card.style.setProperty("--tilt-x", "0deg");
          card.style.setProperty("--tilt-y", "0deg");
        });
      });
    </script>
  </body>
</html>
