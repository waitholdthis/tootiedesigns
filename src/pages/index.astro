---
import "../styles/global.css";
import DecryptedHeroTitle from "../components/DecryptedHeroTitle";
import GrowthSignalConsole from "../components/GrowthSignalConsole";
import LaserIntro from "../components/LaserIntro";
import StandoutGrowthSuite from "../components/StandoutGrowthSuite";
import WowFeatureSuite from "../components/WowFeatureSuite";
import { proofEngine, proofMetrics } from "../data/marketing";
import { primaryCapabilities, depthCapabilities, email, fieldNotes, process as processSteps, projects, tech, techCategories, websiteShowcase } from "../data/site";
import parkerHeadshot from "../../photos/headshot.jpg";
import conversionLandingPageImage from "../../photos/Conversion_Landing_Page.png";
import dugoutCommandCenterImage from "../../photos/The_Dugout_Command_Center.png";
import luxuryServiceWebsiteImage from "../../photos/Luxury_Service_Website.png";
import professionalWebsiteImage from "../../photos/Professional_Website.png";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const deploymentOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "https://tootiedesigns.com";
const deploymentBase = `${deploymentOrigin}${base === "/" ? "" : base.replace(/\/$/, "")}`;
const websiteImages = new Map([
  ["Authority Site", professionalWebsiteImage],
  ["Diverse Hair Designs by Peachie", luxuryServiceWebsiteImage],
  ["The Digital Threshold", conversionLandingPageImage],
  ["Foundry Baseball App", dugoutCommandCenterImage],
]);
const currentYear = new Date().getFullYear();
const latestFieldNotes = [...fieldNotes].sort((a, b) => Date.parse(b.date) - Date.parse(a.date));
const filters = [
  { value: "all", label: "All" },
  { value: "digital", label: "Digital Systems" },
  { value: "tactical", label: "Tactical Advising" },
  { value: "fabrication", label: "Physical Fabrication" },
];

const servicePackages = [
  {
    name: "CEO / Executive Website",
    price: "Starting at $3,500",
    href: `${basePath}ceo-website-design/`,
    description: "A premium authority site or company redesign path for CEOs, founders, consultants, and executive teams that need global trust before the first call.",
    deliverables: ["Executive positioning", "Authority narrative", "Proof architecture", "Premium responsive build", "Investor or enterprise inquiry path"],
  },
  {
    name: "Global Website Redesign",
    price: "Starting at $3,500",
    href: `${basePath}global-website-redesign/`,
    description: "A company redesign path for founders, executive teams, consultants, and premium brands that need to look credible outside their local market.",
    deliverables: ["Company narrative", "Premium redesign system", "Proof sequencing", "Global inquiry path", "SEO-ready launch foundation"],
  },
  {
    name: "Enterprise Landing Page",
    price: "Starting at $2,500",
    href: `${basePath}enterprise-landing-page-design/`,
    description: "A focused campaign or offer page for serious buyers where the page has to create authority, proof, and action without distraction.",
    deliverables: ["Campaign strategy", "High-ticket offer hierarchy", "Conversion copy", "Premium responsive page", "Lead capture or booking path"],
  },
  {
    name: "Website Cleanup Sprint",
    price: "$500 - $750",
    href: `${basePath}website-cleanup-sprint/`,
    description: "A focused cleanup for businesses that do not need a full rebuild yet but need the first impression, CTA, and mobile trust tightened fast.",
    deliverables: ["Homepage first-screen cleanup", "CTA and lead path fixes", "Mobile readability pass", "Trust/proof placement", "Quick-turn launch support"],
  },
  {
    name: "Website Launch",
    price: "Starting at $1,500",
    href: `${basePath}website-design/`,
    description: "A premium web presence for new brands, outdated sites, and businesses that need to look credible fast.",
    deliverables: ["Website strategy", "Responsive page design", "Copy structure", "Contact or booking flow", "Launch-ready deployment"],
  },
  {
    name: "Website Redesign",
    price: "Starting at $1,500",
    href: `${basePath}website-redesign/`,
    description: "A sharper rebuild for businesses whose current site looks outdated, unclear, or too weak to convert referrals.",
    deliverables: ["First-impression audit", "Message cleanup", "Visual refresh", "Lead path rebuild", "Mobile-first launch"],
  },
  {
    name: "Conversion Landing Page",
    price: "Starting at $750",
    href: `${basePath}landing-page-design/`,
    description: "A focused one-page experience for one service, campaign, product, booking push, or audit funnel.",
    deliverables: ["Offer positioning", "Conversion copy", "CTA flow", "Mobile-first layout", "Analytics-ready structure"],
  },
  {
    name: "Digital System Build",
    price: "Custom quote",
    href: `${basePath}digital-system-build/`,
    description: "Dashboards, portals, internal tools, automations, and web apps built around real operational workflows.",
    deliverables: ["System architecture", "Interface design", "Full-stack planning", "API-connected workflows", "Deployment support"],
  },
  {
    name: "Start With the Audit",
    price: "Free first step",
    href: `${basePath}website-audit/`,
    description: "Not sure which path fits? Send the current site first. The audit identifies the lowest-friction move before anyone commits to a build.",
    deliverables: ["First impression review", "Mobile trust check", "Proof gap notes", "Lead path diagnosis", "Recommended next step"],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Tootie Designs builds premium websites, CEO websites, executive authority sites, conversion landing pages, redesigns, and digital systems for businesses that need a sharper first impression and better leads."
    />
    <link rel="canonical" href={deploymentOrigin} />
    <meta property="og:title" content="Tootie Designs | Premium Websites for CEOs, Founders, and Serious Brands" />
    <meta property="og:description" content="Cinematic website design, executive websites, landing pages, website redesigns, and digital systems built to help serious businesses look sharper and generate better leads." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={deploymentOrigin} />
    <meta property="og:image" content={`${deploymentOrigin}${basePath}tootie-logo-transparent.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>Tootie Designs | Premium Websites for CEOs, Founders, and Serious Brands</title>
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        name: "Tootie Designs",
        url: deploymentOrigin,
        image: `${deploymentOrigin}${basePath}tootie-logo-transparent.png`,
        areaServed: ["Fayetteville NC", "North Carolina", "United States", "Global"],
        address: {
          "@type": "PostalAddress",
          addressLocality: "Fayetteville",
          addressRegion: "NC",
          addressCountry: "US",
        },
        priceRange: "$750+",
        description: "Premium website design, CEO websites, conversion landing pages, website redesigns, and digital systems for better business leads.",
        makesOffer: ["CEO Website Design", "Global Website Redesign", "Enterprise Landing Page Design", "Custom Business Software", "Website Cleanup Sprint", "Website Design", "Website Redesign", "Landing Page Design", "Digital System Build"].map((name) => ({
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name,
          },
        })),
      })}
    />
  </head>
  <body>
    <a class="skip-link" href="#top">Skip to main content</a>
    <LaserIntro client:load />
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href="#top" aria-label="Tootie Designs home">
        <span class="brand-mark"><img src={`${basePath}tootie-logo-transparent.png`} alt="" width="37" height="37" /></span>
        <span>Tootie Designs</span>
      </a>
      <button
        class="nav-toggle"
        type="button"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="primary-nav"
      >
        <svg class="icon-open" width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true">
          <rect width="18" height="2" rx="1" fill="currentColor"/>
          <rect y="6" width="18" height="2" rx="1" fill="currentColor"/>
          <rect y="12" width="18" height="2" rx="1" fill="currentColor"/>
        </svg>
        <svg class="icon-close" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <nav id="primary-nav">
        <a href={`${basePath}website-design/`}>Websites</a>
        <a href={`${basePath}website-redesign/`}>Redesigns</a>
        <a href={`${basePath}landing-page-design/`}>Landing Pages</a>
        <a href={`${basePath}local-business-websites/`}>Local</a>
        <a href={`${basePath}digital-system-build/`}>Systems</a>
        <a href="#work">Work</a>
        <a href={`${basePath}website-audit/`}>Request Audit</a>
      </nav>
    </header>

    <main id="top" tabindex="-1">
      <section class="hero section-shell" aria-labelledby="hero-title">
        <div class="hero-media" aria-hidden="true">
          <img src={`${basePath}hero-workshop.png`} alt="" />
          <div class="scanline"></div>
        </div>
        <div class="hero-content">
          <p class="eyebrow">Fayetteville, NC / Digital Workshop</p>
          <DecryptedHeroTitle
            id="hero-title"
            text="Premium websites. Sharper leads. Digital systems that sell."
            revealDirection="start"
            client:load
          />
          <p class="hero-copy">
            Tootie Designs creates cinematic websites, conversion landing pages, and full-stack business tools for CEOs, founders, and serious brands that need a world-class first impression and a cleaner path to revenue.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={`${basePath}website-audit/`} data-event="audit_cta_click" data-label="home hero audit">Request a Free Website Audit</a>
            <a class="button secondary" href="#work" data-event="case_study_click" data-label="home hero work">View Recent Builds</a>
          </div>
          <p class="hero-reassurance">Free first-impression review. No pressure, no obligation.</p>
        </div>
        <aside class="hero-panel" aria-label="Studio pillars">
          <div>
            <span>01</span>
            <strong>First impression</strong>
            <p>Positioning, visuals, and clarity that make a business look serious fast.</p>
          </div>
          <div>
            <span>02</span>
            <strong>Lead path</strong>
            <p>Audit-driven pages, CTAs, and forms built to turn attention into inquiry.</p>
          </div>
          <div>
            <span>03</span>
            <strong>Systems</strong>
            <p>Websites, dashboards, automations, and deployable tools that support the work.</p>
          </div>
        </aside>
      </section>

      <section class="trust-line section-shell" aria-label="Studio trust statement">
        <p>
          Premium websites, landing pages, and digital systems built to help serious businesses look sharper, sell clearer, and generate better leads.
        </p>
        <div class="trust-link-row">
          <a class="project-link trust-link" href={`${basePath}ceo-website-design/`}>CEO and executive website design</a>
          <a class="project-link trust-link" href={`${basePath}global-website-redesign/`}>Global website redesign</a>
          <a class="project-link trust-link" href={`${basePath}enterprise-landing-page-design/`}>Enterprise landing pages</a>
          <a class="project-link trust-link" href={`${basePath}digital-system-build/`}>Custom business software</a>
          <a class="project-link trust-link" href={`${basePath}local-business-websites/`}>Explore local business website design</a>
          <a class="project-link trust-link" href={`${basePath}fayetteville-nc-website-design/`}>Fayetteville NC website design</a>
        </div>
      </section>

      <section class="executive-proof-panel section-shell" aria-labelledby="executive-proof-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Executive Trust Layer</p>
            <h2 id="executive-proof-title">Built for the moment a serious buyer checks whether the company is real.</h2>
          </div>
          <p>CEOs, founders, investors, partners, and enterprise buyers do not only judge the design. They judge the proof sequence, leadership signal, offer clarity, mobile credibility, and seriousness of the next step.</p>
        </div>
        <div class="executive-proof-grid">
          <article>
            <span>Authority</span>
            <h3>Founder and leadership credibility up front.</h3>
            <p>Position the person behind the company without turning the site into a biography.</p>
          </article>
          <article>
            <span>Proof</span>
            <h3>Case studies, outcomes, credentials, and visible work before the CTA.</h3>
            <p>High-value visitors need evidence before they request a call, proposal, or partnership conversation.</p>
          </article>
          <article>
            <span>Inquiry</span>
            <h3>Separate serious inquiries from casual contact.</h3>
            <p>Route executive, enterprise, investor, partnership, and premium service interest into a clearer audit path.</p>
          </article>
        </div>
        <div class="executive-proof-actions">
          <a class="button primary" href={`${basePath}executive-website-audit/`} data-event="audit_cta_click" data-label="home executive audit">Start Executive Website Audit</a>
          <a class="button secondary" href={`${basePath}global-website-redesign/`} data-event="service_page_click" data-label="home global redesign">Explore Global Redesign</a>
        </div>
      </section>

      <section class="growth-diagnostic section-shell" aria-labelledby="growth-diagnostic-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Live Growth Diagnostic</p>
            <h2 id="growth-diagnostic-title">A cinematic control panel that shows what your website is costing you.</h2>
          </div>
          <p>
            Move the signals like a mission board. The console translates weak clarity, trust, mobile flow, proof, and lead capture into the next best Tootie Designs path — audit, cleanup, landing page, redesign, or digital system.
          </p>
        </div>
        <GrowthSignalConsole basePath={basePath} client:load />
      </section>

      <section class="wow-feature-stack section-shell" aria-labelledby="wow-feature-stack-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Conversion Theater</p>
            <h2 id="wow-feature-stack-title">Five premium experiences that turn curiosity into a serious project path.</h2>
          </div>
          <p>
            Tootie Designs should not feel like a normal agency site. This stack turns the homepage into an interactive sales environment: brief the mission, see the transformation, stage the audit, choose the path, and unlock proof.
          </p>
        </div>
        <WowFeatureSuite basePath={basePath} client:load />
      </section>

      <section class="next-five-stack section-shell" aria-labelledby="next-five-title" data-homepage-rhythm-map>
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Next Five Moves</p>
            <h2 id="next-five-title">The homepage becomes a diagnostic product, proof theater, and operating-system preview.</h2>
          </div>
          <p>
            This is the competitor gap: not another agency portfolio, but a cinematic buyer journey that audits the site, previews the rebuild, opens case-study rooms, and shows the system behind the work.
          </p>
        </div>
        <StandoutGrowthSuite basePath={basePath} client:load />
      </section>

      <section class="audit-funnel section-shell" id="audit" aria-labelledby="audit-title">
        <div class="audit-copy">
          <p class="eyebrow">Free Website First-Impression Audit</p>
          <h2 id="audit-title">Not sure if your website is helping or hurting you?</h2>
          <p>
            Send your current website, business page, or idea. Tootie Designs will review the first impression, mobile experience, message clarity, trust signals, and conversion path — then show you what needs to change.
          </p>
          <ul class="audit-checklist" aria-label="Website audit review points">
            <li>First-screen clarity</li>
            <li>Mobile experience</li>
            <li>Trust and proof signals</li>
            <li>Lead capture path</li>
          </ul>
          <a class="project-link audit-sample-link" href={`${basePath}sample-website-audit/`} data-event="sample_audit_click" data-label="audit section sample preview">Preview a sample audit report</a>
        </div>
        <form class="audit-form" name="website-audit" method="post" action="https://formsubmit.co/tootiedesigns18@gmail.com" data-event="audit_form_submit">
          <input type="hidden" name="_subject" value="New Website First-Impression Audit Request" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value={`${deploymentBase}/thanks/`} />
          <input type="hidden" name="lead_type" value="Website first-impression audit" />
          <input type="hidden" name="source_page" value="Homepage audit funnel" />
          <input type="hidden" name="referrer" value="Direct / unknown" />
          <input type="text" name="_honey" class="form-honey" tabindex="-1" autocomplete="off" />
          <label>
            <span class="field-label-text">Name<span class="required-mark" aria-hidden="true">*</span></span>
            <input name="name" autocomplete="name" required />
          </label>
          <label>
            <span class="field-label-text">Email<span class="required-mark" aria-hidden="true">*</span></span>
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label class="full-field">
            Current website or business page
            <input name="website-or-page" type="url" placeholder="https://" />
          </label>
          <label>
            What do you want more of?
            <select name="goal">
              <option>More leads</option>
              <option>More bookings</option>
              <option>More sales</option>
              <option>More credibility</option>
              <option>Launch help</option>
            </select>
          </label>
          <label>
            Timeline
            <select name="timeline">
              <option>Just want the audit first</option>
              <option>Ready to improve this month</option>
              <option>Need a fast launch</option>
              <option>Planning for later</option>
            </select>
          </label>
          <label>
            Possible next step
            <select name="possible-next-step">
              <option>Audit first — show me what is broken</option>
              <option>Website cleanup sprint</option>
              <option>Landing page</option>
              <option>Full website launch or redesign</option>
              <option>Custom software / digital system</option>
            </select>
          </label>
          <label>
            Budget comfort
            <select name="budget-comfort">
              <option>Need guidance after audit</option>
              <option>$500 - $750 cleanup sprint</option>
              <option>$750 - $1,500 landing page</option>
              <option>$1,500 - $3,500 website build</option>
              <option>$3,500+ larger system</option>
            </select>
          </label>
          <label class="full-field">
            What feels broken, outdated, or unclear?
            <textarea name="message" rows="4" placeholder="Tell us what you want the site to do better."></textarea>
          </label>
          <button class="button primary" type="submit" data-event="audit_form_submit" data-label="homepage audit form">Get My Website Audit</button>
        </form>
      </section>

      <section class="offer-ladder section-shell" aria-labelledby="offer-ladder-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">After the audit</p>
            <h2 id="offer-ladder-title">A clear next move for every level of urgency.</h2>
          </div>
          <p>The free audit shows what is costing trust. The next step can stay light, focused, or become a full rebuild depending on what the business actually needs.</p>
        </div>
        <div class="ladder-grid">
          <article>
            <span>01</span>
            <h3>Website Cleanup Sprint</h3>
            <strong>$500 - $750</strong>
            <p>For businesses that need a sharper hero, CTA, mobile pass, trust signals, and fast credibility improvements without rebuilding everything.</p>
            <a class="project-link" href={`${basePath}website-cleanup-sprint/`} data-event="service_page_click" data-label="offer ladder cleanup sprint">Explore cleanup sprint</a>
          </article>
          <article>
            <span>02</span>
            <h3>Conversion Landing Page</h3>
            <strong>Starting at $750</strong>
            <p>For one focused service, offer, booking path, campaign, or local lead push that needs a dedicated conversion page.</p>
            <a class="project-link" href={`${basePath}landing-page-design/`} data-event="service_page_click" data-label="offer ladder landing page">Explore landing pages</a>
          </article>
          <article>
            <span>03</span>
            <h3>Website Launch / Redesign</h3>
            <strong>Starting at $1,500</strong>
            <p>For businesses ready to replace a weak first impression with a premium site built around message clarity, proof, and inquiry.</p>
            <a class="project-link" href={`${basePath}website-redesign/`} data-event="service_page_click" data-label="offer ladder redesign">Explore redesigns</a>
          </article>
          <article>
            <span>04</span>
            <h3>Digital System Build</h3>
            <strong>Custom quote</strong>
            <p>For dashboards, portals, automations, web apps, and internal tools where the website becomes part of a larger operating system.</p>
          </article>
        </div>
      </section>

      <section class="statement section-shell" aria-label="Brand statement">
        <p class="bridge-highlight active">
          <span>Applying the </span><span class="highlight-bit">precision</span><span> of military planning and the logic of </span><span class="highlight-bit">full-stack engineering</span><span> to every medium, from digital interfaces to </span><span class="highlight-bit">physical fabrication</span><span>.</span>
        </p>
      </section>

      <section class="proof-band section-shell" aria-label="Studio proof points">
        <div>
          <span>01</span>
          <strong>Strategy to launch</strong>
          <p>Positioning, copy, interface design, development, and deployment.</p>
        </div>
        <div>
          <span>02</span>
          <strong>Defense-informed precision</strong>
          <p>Built from Fayetteville, NC with respect for clarity, service, and execution.</p>
        </div>
        <div>
          <span>03</span>
          <strong>Backed by real depth</strong>
          <p>Fabrication, tactical advising, and material craft complement the core digital work.</p>
        </div>
      </section>



<section class="proof-engine section-shell" id="proof" aria-labelledby="proof-engine-title">
  <div class="section-heading split">
    <div>
      <p class="eyebrow">Proof Engine</p>
      <h2 id="proof-engine-title">Proof that Tootie Designs knows how to turn a weak first impression into a cleaner lead path.</h2>
    </div>
    <p>
      Until every project has public numbers and testimonials, the proof engine focuses on visible business improvements: clearer positioning, stronger mobile flow, sharper CTAs, and pages built around trust.
    </p>
  </div>
  <div class="proof-metric-grid" aria-label="What the audit looks for">
    {proofMetrics.map(([label, text]) => (
      <article>
        <strong>{label}</strong>
        <p>{text}</p>
      </article>
    ))}
  </div>
  <div class="before-after-grid">
    {proofEngine.map((item) => (
      <article class="before-after-card">
        <p class="eyebrow">{item.label}</p>
        <h3>{item.title}</h3>
        <div class="before-after-columns">
          <div>
            <span>Before</span>
            <p>{item.before}</p>
          </div>
          <div>
            <span>After</span>
            <p>{item.after}</p>
          </div>
        </div>
        <ul>
          {item.evidence.map((proof) => <li>{proof}</li>)}
        </ul>
        <a class="project-link" href={item.href}>View proof card</a>
      </article>
    ))}
  </div>
</section>

      <section class="brand-lockup section-shell" aria-label="Brand system">
        <div class="brand-sigil"><img src={`${basePath}tootie-logo-transparent.png`} alt="Tootie Designs multidisciplinary creation logo" /></div>
        <div>
          <p class="eyebrow">Studio Standard</p>
          <h2>Design that can brief, build, and finish.</h2>
        </div>
        <p>
          Tootie Designs leads with strategic web creation and software systems — backed by
          defense-informed planning, digital fabrication, and material craft when the project
          calls for it. One visual language: industrial elegance, disciplined grids, and precise finish.
        </p>
      </section>

      <section class="section-shell" id="capabilities" aria-labelledby="capabilities-title">
        <div class="section-heading">
          <p class="eyebrow">Capabilities</p>
          <h2 id="capabilities-title">Web and software, front and center.</h2>
        </div>
        <div class="capability-grid">
          {
            primaryCapabilities.map((capability) => (
              <article class="capability-card">
                <p>{capability.kicker}</p>
                <h3>{capability.title}</h3>
                <span></span>
                <p>{capability.description}</p>
                <ul>
                  {capability.services.map((service) => <li>{service}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
        <div class="package-strip" aria-labelledby="packages-title">
          <div class="section-heading split package-heading">
            <div>
              <p class="eyebrow">Ways to Work</p>
              <h2 id="packages-title">Clear offers. Serious outcomes.</h2>
            </div>
            <p>
              Start with an audit, then move into the build that matches the business objective: launch, conversion, or custom systems.
            </p>
          </div>
          <div class="package-grid">
            {
              servicePackages.map((offer) => (
                <article class="package-card">
                  <div>
                    <p class="eyebrow">{offer.name}</p>
                    <strong>{offer.price}</strong>
                  </div>
                  <p>{offer.description}</p>
                  <ul>
                    {offer.deliverables.map((item) => <li>{item}</li>)}
                  </ul>
                  <a class="project-link" href={offer.href} data-event="service_page_click" data-label={offer.name}>Explore this path</a>
                </article>
              ))
            }
          </div>
        </div>
        <div class="depth-strip">
          <p class="eyebrow">Studio Depth</p>
          <div class="depth-capability-grid">
            {
              depthCapabilities.map((cap) => (
                <article class="depth-capability-card">
                  <p>{cap.kicker}</p>
                  <h3>{cap.title}</h3>
                  <p>{cap.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section-shell website-showcase" aria-labelledby="website-showcase-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Website Design Showcase</p>
            <h2 id="website-showcase-title">Digital Lab builds made to look credible on arrival.</h2>
          </div>
          <a class="button secondary" href={`${basePath}work/website-design-portfolio/`}>View Website Case Study</a>
        </div>
        <div class="website-grid">
          {
            websiteShowcase.map((item) => {
              const image = websiteImages.get(item.title);

              return (
                <article class="website-card">
                  <div class:list={["website-frame", image && "has-image"]} aria-hidden="true">
                    {image ? (
                      <img src={image.src} alt="" loading="lazy" />
                    ) : (
                      <>
                        <span></span>
                        <span></span>
                        <span></span>
                      </>
                    )}
                  </div>
                  <p class="eyebrow">{item.type}</p>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                  <div>
                    {item.highlights.map((highlight) => <span>{highlight}</span>)}
                  </div>
                </article>
              );
            })
          }
        </div>
      </section>

      <section class="section-shell work-section" id="work" aria-labelledby="work-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Selected Work</p>
            <h2 id="work-title">A portfolio organized by discipline, not by limitation.</h2>
          </div>
        </div>

        <div class="filter-bar" aria-label="Project filters">
          {
            filters.map((filter, index) => (
              <button
                class={index === 0 ? "filter-button active" : "filter-button"}
                type="button"
                data-filter={filter.value}
                aria-pressed={index === 0 ? "true" : "false"}
              >
                {filter.label}
              </button>
            ))
          }
        </div>

        <div class="project-grid" data-project-grid>
          {
            projects.map((project) => (
              <a
                href={`${basePath}work/${project.slug}/`}
                class={`project-card spotlight-card ${project.size}`}
                data-category={project.filter}
                style="--spotlight-x:50%;--spotlight-y:50%;--tilt-x:0deg;--tilt-y:0deg"
              >
                <div class="project-texture" aria-hidden="true"></div>
                <div class="project-topline">
                  <span>{project.category}</span>
                  <span>{project.meta}</span>
                </div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <span class="project-link">View Case Study</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section-shell blueprint" aria-labelledby="blueprint-title">
        <div class="blueprint-visual perspective-visual" aria-hidden="true">
          <video class="blueprint-video" autoplay muted loop playsinline>
            <source src={`${basePath}videos/blueprint.mp4`} type="video/mp4" />
          </video>
          <div class="perspective-grid">
            {Array.from({ length: 18 }).map((_, index) => <span class="grid-line horizontal" style={`--i:${index}`}></span>)}
            {Array.from({ length: 15 }).map((_, index) => <span class="grid-line vertical" style={`--i:${index}`}></span>)}
          </div>
          <div class="vector-card">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
        <div class="blueprint-copy">
          <p class="eyebrow">Blueprint to Reality</p>
          <h2 id="blueprint-title">From concept path to finished surface.</h2>
          <p>
            Every engagement moves through the same disciplined arc: clarify the target,
            design the system, execute the build, then refine the finish until the work
            feels inevitable.
          </p>
        </div>
      </section>

      <section class="section-shell" id="process" aria-labelledby="process-title">
        <div class="section-heading">
          <p class="eyebrow">Process</p>
          <h2 id="process-title">The workshop method.</h2>
        </div>
        <div class="process-grid">
          {
            processSteps.map(([number, title, description]) => (
              <article class="process-card">
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-shell tools-section" aria-labelledby="tools-title">
        <div class="section-heading">
          <p class="eyebrow">Stack</p>
          <h2 id="tools-title">Tools &amp; Technologies</h2>
        </div>
        <div class="tools-grid">
          {
            techCategories.map((cat) => (
              <div class="tools-category">
                <strong>{cat.label}</strong>
                <div class="tools-pills">
                  {cat.tools.map((tool) => <span>{tool}</span>)}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="tech-ticker" aria-label="Technology and materials">
        <div>
          {[...tech, ...tech].map((item) => <span>{item}</span>)}
        </div>
      </section>

      <section class="section-shell about" id="about" aria-labelledby="about-title">
        <div class="about-grid">
          <div class="about-photo-col">
            <img
              class="about-headshot"
              src={parkerHeadshot.src}
              alt="Parker Tootill, founder of Tootie Designs"
              loading="lazy"
            />
          </div>
          <div class="about-copy-col">
            <p class="eyebrow">About the Studio</p>
            <h2 id="about-title">Parker Tootill</h2>
            <p class="about-role">Founder / Designer &amp; Strategic Advisor</p>
            <p>
              Parker Tootill is a designer and strategist based in Fayetteville, North Carolina.
              With a background in military planning and defense systems, Parker founded Tootie Designs
              to apply that same precision to creative and technical work — web systems, software builds,
              laser fabrication, and material craft.
            </p>
            <p>
              The studio operates on a single discipline across every medium: structure first, then finish.
              The same thinking that produces a clear planning artifact produces a clean interface, a
              precise laser path, or a well-finished wood surface.
            </p>
          </div>
        </div>
      </section>

      <section class="section-shell field-notes-preview" aria-labelledby="field-notes-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Field Notes</p>
            <h2 id="field-notes-title">Thinking from the studio.</h2>
          </div>
          <a class="button secondary" href={`${basePath}notes/`}>Read All Notes</a>
        </div>
        <div class="notes-preview-grid">
          {
            latestFieldNotes.slice(0, 3).map((note) => (
              <a class="note-card" href={`${basePath}notes/${note.slug}/`}>
                <span class="note-eyebrow">{note.eyebrow}</span>
                <strong>{note.title}</strong>
                <p>{note.summary}</p>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section-shell contact" id="contact" aria-labelledby="contact-title">
        <div>
          <p class="eyebrow">Start a Project</p>
          <h2 id="contact-title">Ready to turn the audit into a build?</h2>
          <p>
            If you already know the mission, use the full project form. Website launches, landing pages, digital systems, fabrication, and advisory work all start with a clear brief.
          </p>
          <p class="contact-direct-email">
            Or reach out directly: <a href={`mailto:${email}`}>{email}</a>
          </p>
        </div>
        <form name="contact" method="post" action="https://formsubmit.co/tootiedesigns18@gmail.com" data-event="contact_form_submit">
          <input type="hidden" name="_subject" value="New Tootie Designs Inquiry" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value={`${deploymentBase}/thanks/`} />
          <input type="hidden" name="lead_type" value="General project inquiry" />
          <input type="hidden" name="source_page" value="Homepage project form" />
          <input type="hidden" name="referrer" value="Direct / unknown" />
          <input type="text" name="_honey" class="form-honey" tabindex="-1" autocomplete="off" />
          <label>
            <span class="field-label-text">Name<span class="required-mark" aria-hidden="true">*</span></span>
            <input name="name" autocomplete="name" required />
          </label>
          <label>
            <span class="field-label-text">Email<span class="required-mark" aria-hidden="true">*</span></span>
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label>
            Project Type
            <select name="project-type">
              <option>Free Website First-Impression Audit</option>
              <option>Website Design / Creation</option>
              <option>Software / Web App Project</option>
              <option>Defense / Advising Inquiry</option>
              <option>Laser / Wood Fabrication</option>
              <option>Handmade / Material Commission</option>
              <option>General Collaboration</option>
            </select>
          </label>
          <label>
            Timeline
            <select name="timeline">
              <option>Exploring options</option>
              <option>Ready to start this month</option>
              <option>Need a fast launch</option>
              <option>Planning for a future phase</option>
            </select>
          </label>
          <label>
            Budget Range
            <select name="budget">
              <option>Not sure yet</option>
              <option>Under $1,000</option>
              <option>$1,000 - $3,000</option>
              <option>$3,000 - $7,500</option>
              <option>$7,500+</option>
            </select>
          </label>
          <label>
            Existing Website or Reference
            <input name="reference" type="url" placeholder="https://" />
          </label>
          <label>
            <span class="field-label-text">Brief<span class="required-mark" aria-hidden="true">*</span></span>
            <textarea name="brief" rows="4" required></textarea>
          </label>
          <button class="button primary" type="submit">Send Project Brief</button>
        </form>
      </section>
    </main>

    <footer class="site-footer">
      <div>
        <strong>Tootie Designs</strong>
        <span>Fayetteville, NC</span>
      </div>
      <div>
        <span>Website Design / Software / Tactical Advising / Fabrication</span>
        <span>Precision / Texture / Innovation</span>
        <span>© {currentYear} Tootie Designs.</span>
        <div class="footer-links">
          <a href="https://www.facebook.com/profile.php?id=100063801085109" target="_blank" rel="noreferrer">Facebook</a>
          <a href={`${basePath}privacy/`}>Privacy Policy</a>
        </div>
      </div>
    </footer>
    <script is:inline>
      // Filter buttons
      const filterButtons = document.querySelectorAll("[data-filter]");
      const projectCards = document.querySelectorAll(".project-card[data-category]");

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const activeFilter = button.dataset.filter;
          filterButtons.forEach((item) => {
            item.classList.toggle("active", item === button);
            item.setAttribute("aria-pressed", String(item === button));
          });
          projectCards.forEach((card) => {
            card.classList.toggle("is-hidden", activeFilter !== "all" && card.dataset.category !== activeFilter);
          });
        });
      });

      // Project card spotlight effect
      projectCards.forEach((card) => {
        card.addEventListener("pointermove", (event) => {
          const rect = card.getBoundingClientRect();
          const px = (event.clientX - rect.left) / rect.width;
          const py = (event.clientY - rect.top) / rect.height;
          card.style.setProperty("--spotlight-x", `${px * 100}%`);
          card.style.setProperty("--spotlight-y", `${py * 100}%`);
          card.style.setProperty("--tilt-x", `${(0.5 - py) * 5}deg`);
          card.style.setProperty("--tilt-y", `${(px - 0.5) * 6}deg`);
        });

        card.addEventListener("pointerleave", () => {
          card.style.setProperty("--spotlight-x", "50%");
          card.style.setProperty("--spotlight-y", "50%");
          card.style.setProperty("--tilt-x", "0deg");
          card.style.setProperty("--tilt-y", "0deg");
        });
      });

      // Mobile nav toggle
      const navToggle = document.querySelector(".nav-toggle");
      const primaryNav = document.getElementById("primary-nav");

      if (navToggle && primaryNav) {
        navToggle.addEventListener("click", () => {
          const expanded = navToggle.getAttribute("aria-expanded") === "true";
          navToggle.setAttribute("aria-expanded", String(!expanded));
          navToggle.setAttribute("aria-label", !expanded ? "Close navigation" : "Open navigation");
          primaryNav.classList.toggle("is-open", !expanded);
        });

        primaryNav.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            navToggle.setAttribute("aria-expanded", "false");
            navToggle.setAttribute("aria-label", "Open navigation");
            primaryNav.classList.remove("is-open");
          });
        });

        document.addEventListener("click", (e) => {
          if (!e.target.closest(".site-header")) {
            navToggle.setAttribute("aria-expanded", "false");
            navToggle.setAttribute("aria-label", "Open navigation");
            primaryNav.classList.remove("is-open");
          }
        });
      }

      // Contact form submit loading state
      const contactForm = document.querySelector("form[name='contact']");
      const submitBtn = contactForm?.querySelector("button[type='submit']");

      contactForm?.addEventListener("submit", () => {
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Sending…";
        }
      });
    </script>
    <script src={`${basePath}analytics-events.js`} defer></script>
  </body>
</html>
